# ============================================================
# LLM Provider Configuration
# ============================================================
# Pi supports these providers natively:
#   Anthropic, OpenAI, Google, OpenRouter, Azure OpenAI,
#   Groq, xAI, Cerebras, Mistral, MiniMax
#
# For DeepSeek (or any OpenAI-compatible provider not listed above),
# use OpenRouter as a proxy: https://openrouter.ai
# Set your OpenRouter key below, then set PI_MODEL to the model ID.

# --- Option A: OpenRouter (supports DeepSeek, Llama, etc.) ---
OPENROUTER_API_KEY=
PI_MODEL=openrouter/deepseek/deepseek-r1

# --- Option B: Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-...
# PI_MODEL=anthropic/claude-sonnet-4-20250514

# --- Option C: OpenAI ---
# OPENAI_API_KEY=sk-...
# PI_MODEL=openai/gpt-4o

# --- Option D: Google Gemini ---
# GOOGLE_API_KEY=AIza...
# PI_MODEL=google/gemini-2.5-pro

# ============================================================
# Backend
# ============================================================
ASPNETCORE_ENVIRONMENT=Development
LIBRARY_PATH=/library

# ============================================================
# Frontend
# ============================================================
PUBLIC_API_BASE=http://localhost:5000
