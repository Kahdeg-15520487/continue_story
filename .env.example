# ============================================================
# LLM Provider Configuration
# ============================================================
# Pick one provider, set its API key and PI_MODEL.
# The agent reads agent/models.json which registers custom providers.

# --- DeepSeek ---
DEEPSEEK_API_KEY=
PI_MODEL=deepseek/deepseek-reasoner

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-...
# PI_MODEL=anthropic/claude-sonnet-4-20250514

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# PI_MODEL=openai/gpt-4o

# --- Google Gemini ---
# GOOGLE_API_KEY=AIza...
# PI_MODEL=google/gemini-2.5-pro

# --- OpenRouter (proxies many providers) ---
# OPENROUTER_API_KEY=sk-or-...
# PI_MODEL=openrouter/deepseek/deepseek-r1

# ============================================================
# Backend
# ============================================================
ASPNETCORE_ENVIRONMENT=Development
LIBRARY_PATH=/library

# ============================================================
# Frontend
# ============================================================
PUBLIC_API_BASE=http://localhost:5000
